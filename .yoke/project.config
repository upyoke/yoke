# Yoke project settings overlay (key=value).
#
# Unset keys inherit machine config (~/.yoke/config.json:settings).
# This file is project-owned policy with teeth: it rides the repo, so a
# pulled commit can change the project's stance (the lint-config
# precedent). Every recognized key resolves scope-first:
#   this file's <key>
#   -> machine settings <key>
#   -> source default
# (The do_process_offer_* family adds a per-scope default rung:
# project key -> project default -> machine key -> machine default
# -> off; autonomy is opt-in.)
#
# /yoke do process autonomy — may the scheduler autonomously dispatch
# these processes for Yoke? Uncomment to set a project stance:
# do_process_offer_default=false
# do_process_offer_strategize=false
# do_process_offer_feed=false
# do_process_offer_doctor=false
#
# Recognized scalar settings, shown at their source defaults.
# Uncomment to set a project stance:
# base_branch=main  # trunk branch worktrees branch from and merges land on
# wip_cap=5  # scheduler WIP cap for conduct-eligible items
# worktrees_dir=.worktrees  # checkout-relative directory holding linked worktrees
# default_priority=medium  # priority assigned to new backlog items when none is given
# merge_conflict_threshold=2  # rebase auto-resolve passes allowed before falling back to merge
# max_attempts=5  # dispatch attempts per epic task before the chain halts
# file_line_limit=350  # authored-file line limit enforced by local hooks and check commands
