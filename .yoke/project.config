# Project config for Yoke (key=value).
#
# The on-disk home for project settings that must be readable without a
# database or a network — anything a git hook, a fresh clone, or an
# offline check needs. It rides the repo, so a pulled commit can change
# the project's stance. Shared behavior that only server-side code reads
# (base_branch, wip_cap, default_priority, merge_conflict_threshold,
# max_attempts) stays in the `project-policy` capability in the database;
# worktrees_dir is a machine checkout fact in ~/.yoke/config.json.
#
# Blank lines and lines starting with # are ignored. A trailing `# ...`
# after a value is documentation, not part of the value.
#
# /yoke do process autonomy — may the scheduler autonomously dispatch
# these processes for Yoke? Resolution is scope-first with a per-scope
# default rung: project key -> project default -> machine key -> machine
# default -> off; autonomy is opt-in. Uncomment to set a project stance:
# do_process_offer_default=false
# do_process_offer_strategize=false
# do_process_offer_feed=false
# do_process_offer_doctor=false
#
# Authored-file line limit, enforced by the pre-commit hook and
# `yoke check file-line`. Unset means 350.
# file_line_limit=350
#
# Files exempt from that limit: intentionally unsplittable artifacts or
# non-authored data. Do not use this to avoid splitting normal source.
file_line_exception=packages/yoke-contracts/src/yoke_contracts/project_contract/board_art/data/mixed_emoji_columns.txt
file_line_exception=packaging/public-installer/install
file_line_exception=packaging/public-installer/install.py

# Shipped reference-doc tree: yoke-authoritative reference material
# (schema catalogs, command references) that installs into managed
# projects, legitimately long, not authored code. Also exempt built-in
# via file_line_policy.GENERATED_PATH_GLOBS once the new engine is installed.
file_line_exception=.yoke/docs/**

# pytest-xdist timing cache: generated data committed so parallel test runs
# balance, never hand-authored source.
file_line_exception=.test_durations
