# {{project_display_name}} Environment Variables
# Copy to .env and fill in values: cp .env.example .env

# Required — Path to SQLite database file
APP_DB_PATH=/app/data/{{project_name}}.db

# Required — Secret key for cookie/session signing (generate a random string)
APP_SECRET_KEY=change-me-to-random-string

# Required (first run) — Initial superadmin password
APP_ADMIN_PASSWORD=change-me

# Optional — Anthropic API key for LLM features
# ANTHROPIC_API_KEY=sk-ant-...

# Optional — API URL for frontend to reach backend (set in docker-compose)
# API_URL=http://api:{{api_port}}

# Optional — CORS origins (comma-separated)
# APP_CORS_ORIGINS=http://localhost:{{web_port}}

# Optional — API bind host/port (defaults shown)
# APP_HOST=0.0.0.0
# APP_PORT={{api_port}}
