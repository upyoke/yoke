# Rendered by the ephemeral-deploy executor for a branch preview of Yoke's core
# service. This integration is project-owned because its service shape is not
# a generic web application Pack. Every deploy rewrites the remote copy from
# this repository source plus DB-backed preview policy.
# Source project: {{project}} / slug: {{slug}}.
name: {{compose_project}}
services:
  db:
    container_name: {{compose_project}}-db
    image: postgres:16
    restart: unless-stopped
    environment:
      POSTGRES_DB: {{database_name}}
      POSTGRES_USER: {{database_user}}
      # Hex-only generated secret (Compose interpolates $ in env values).
      POSTGRES_PASSWORD: ${EPHEMERAL_DB_PASSWORD}
    volumes:
      - pgdata:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U {{database_user}} -d {{database_name}}"]
      interval: 5s
      timeout: 3s
      retries: 24
  core:
    container_name: {{compose_project}}-core
    image: {{image_ref}}
    restart: unless-stopped
    env_file: .env
    depends_on:
      db:
        condition: service_healthy
    # The DSN rides its own file because Compose interpolates $ in env values.
    volumes:
      - ./dsn:/run/yoke/dsn:ro
    ports:
      - "127.0.0.1:{{api_port}}:{{container_port}}"
    # Preview logs remain in Docker on the host; this disposable tier does not
    # provision per-branch CloudWatch resources.
volumes:
  pgdata:
