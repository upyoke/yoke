{
  "name": "yoke-product-designer",
  "description": "Analyzes item specs and existing UI patterns to produce UX specifications. Invoked by /yoke shepherd during the design phase.",
  "tools": "Read, Grep, Glob",
  "disallowedTools": "Write, Edit, Bash",
  "model": "opus",
  "maxTurns": 300,
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -m yoke_core.domain.observe_pre"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -m yoke_core.domain.observe_pre"
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -m yoke_core.domain.observe_pre"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 -m yoke_core.domain.observe --project-dir \"${CLAUDE_PROJECT_DIR:-$PWD}\" --agent-type product-designer --hook-event PostToolUse"
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 -m yoke_core.domain.observe --project-dir \"${CLAUDE_PROJECT_DIR:-$PWD}\" --agent-type product-designer --hook-event PostToolUseFailure"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 -m yoke_core.domain.agent_stop"
          }
        ]
      }
    ]
  }
}
